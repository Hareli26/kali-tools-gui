# ============================================================
#  Kali Tools GUI - VPS deployment config
#  Copy to deploy.env and fill in your values, then run install-vps.sh
# ============================================================

# Your domain (an A record must already point to this VPS's public IP)
DOMAIN="kali.example.com"

# Google OAuth credentials (from Google Cloud Console -> APIs & Services -> Credentials)
# Authorized redirect URI in Google must be: https://<DOMAIN>/oauth2/callback
GOOGLE_CLIENT_ID="xxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxxxxxxxxxx"

# The first approved user (you). More can be added later to authenticated-emails.txt
ADMIN_EMAIL="hareli26@gmail.com"

# App install location on the VPS
APP_DIR="/opt/kali-gui"

# oauth2-proxy version to install
OAUTH2_PROXY_VERSION="7.6.0"

# Optional extra shared token between oauth2-proxy and the app (defense in depth).
# Leave empty to skip. If set, it is injected as a header by oauth2-proxy is NOT
# automatic - the app checks KALIGUI_TOKEN; keep empty unless you know you need it.
KALIGUI_TOKEN=""
